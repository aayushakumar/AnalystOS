# AnalystOS Environment Configuration
# Copy to backend/.env and fill in your keys

# --- LLM Provider Keys ---
# Groq (free tier — recommended for development)
GROQ_API_KEY=gsk_your_key_here

# OpenAI (optional, paid)
# OPENAI_API_KEY=sk-...

# Anthropic (optional, paid)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Model Configuration ---
# Free tier: use 8b for both (500K tokens/day limit)
ANALYST_PRIMARY_MODEL=groq/llama-3.1-8b-instant
ANALYST_CHEAP_MODEL=groq/llama-3.1-8b-instant

# Upgrade: use 70b primary for better quality (100K tokens/day)
# ANALYST_PRIMARY_MODEL=groq/llama-3.3-70b-versatile
# ANALYST_CHEAP_MODEL=groq/llama-3.1-8b-instant

# --- Database ---
DUCKDB_PATH=data/analystos.duckdb
TRACE_DB_PATH=data/traces.db

# --- Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# For deployment: comma-separated allowed origins
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
